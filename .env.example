# ── Notion ──────────────────────────────────────────────────────────────────────
# 1. Duplica las plantillas desde los links en CLONAR-SISTEMA.md → Sección 6
# 2. Crea una Notion Integration en https://www.notion.so/my-integrations
# 3. Copia el "Internal Integration Token" aqui
NOTION_TOKEN=secret_xxx

# IDs de tus DBs duplicadas (copialos de la URL de cada DB en Notion)
NOTION_RAW_SAVES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_CONTENT_IDEAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Meta / Instagram Graph API ───────────────────────────────────────────────────
# Ver instrucciones completas en CLONAR-SISTEMA.md → Seccion 9
# Token de usuario de larga duracion (60 dias) con permiso user_saved_media
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Tu Instagram User ID (numerico — obtenlo desde Graph API Explorer)
# GET https://graph.facebook.com/me?fields=id&access_token=TU_TOKEN
IG_USER_ID=123456789012345

# ── APIs de IA ───────────────────────────────────────────────────────────────────
# Claude — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxx

# AssemblyAI — https://www.assemblyai.com → Dashboard → API Key
ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configuracion del pipeline ───────────────────────────────────────────────────
CONTENT_NICHE=beginner AI solo founders
CONTENT_PILLARS=Outreach,Proof,Tools,Process
